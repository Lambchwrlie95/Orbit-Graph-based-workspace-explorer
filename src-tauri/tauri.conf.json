{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orbit",
  "version": "0.1.0",
  "identifier": "local.orbit.file-intelligence",
  "build": {
    "beforeDevCommand": "npm run dev --prefix frontend",
    "beforeBuildCommand": "npm run build --prefix frontend",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Orbit",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "System",
    "shortDescription": "Graph-first file intelligence IDE",
    "longDescription": "Orbit is a graph-first file intelligence IDE that helps you understand files through relationships: folders, imports, links, tags, assets, and recent work.",
    "publisher": "Orbit",
    "copyright": "Copyright (c) 2026",
    "homepage": "https://orbit-app.dev",
    "deb": {
      "desktopTemplate": "./orbit.desktop"
    },
    "rpm": {
      "desktopTemplate": "./orbit.desktop"
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
